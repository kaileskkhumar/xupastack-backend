{
  "name": "@xupastack/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured'",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply xupastack-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply xupastack-db"
  },
  "dependencies": {
    "@xupastack/shared": "workspace:*",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.3.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240524.0",
    "drizzle-kit": "^0.21.4",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18",
    "wrangler": "^3.60.0"
  }
}
